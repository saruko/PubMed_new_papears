# ============================================================
# PubMed 新着論文レポート — 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# ============================================================

# --- Gemini API (Google AI) ---
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gemini モデル名 ---
# 例: gemini-2.0-flash, gemini-1.5-pro 等
GEMINI_MODEL=gemini-2.0-flash

# --- PubMed (Entrez) ---
# NCBI は利用者のメールアドレスを要求します
ENTREZ_EMAIL=your_email@example.com

# --- 検索設定 ---
# 日本語キーワード（自動的に英語医学用語に変換されます）
SEARCH_KEYWORDS=眼科
# 過去何日分の論文を取得するか
SEARCH_DAYS=7
# 最大取得件数
MAX_RESULTS=50

# --- SMTP メール送信 ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# --- 送信先（カンマ区切りで複数指定可） ---
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com

# --- デバッグモード ---
# true にするとメール送信をスキップし、HTMLをローカルファイルに出力します
DEBUG_MODE=false
# デバッグ時のHTML出力先
DEBUG_OUTPUT_FILE=debug_report.html
